# BTC-Pulse Configuration
# Copy to config.yaml and fill in your keys

# API Keys — all core data is FREE (no paid APIs required)
api_keys:
  # Exchange data — public endpoints, no key needed
  binance_public: ""
  okx_public: ""
  bybit_public: ""

  # AI Sentiment — choose one:
  #   DeepSeek (cheap): set provider + key + url
  #   Ollama (free/local): set provider to "ollama", url to localhost
  #   OpenAI (paid): set provider to "openai"
  ai_provider: "deepseek"          # "deepseek" | "ollama" | "openai"
  ai_api_key: ""                   # DeepSeek or OpenAI key (leave blank for Ollama)
  ai_base_url: "https://api.deepseek.com"  # or http://localhost:11434/v1 for Ollama

# Data Settings
data:
  db_path: "data/btc_pulse.db"
  snapshot_dir: "data/snapshots"
  log_dir: "logs"
  symbol: "BTC/USDT"
  futures_symbol: "BTC/USDT:USDT"
  exchange: "binance"              # Secondary source for daily OHLCV (fallback: okx, bybit, kraken)
  start_date: "2020-01-01"        # ISO date for initial exchange fetch (Bitcoinity always fetches full history)
  # Primary price+volume source: Bitcoinity CSV (monthly, back to 2010, always free)

# Ingestion Schedule
schedule:
  daily_hour: 8
  daily_minute: 5
  timezone: "UTC"

# Feature Engineering
features:
  ma_periods: [7, 14, 30, 90, 200]
  fng_extreme_low: 20
  fng_extreme_high: 80
  funding_cumulative_days: 30
  funding_overweight_threshold: 0.015  # 1.5%

# Model Settings
model:
  xgboost:
    n_estimators: 200
    max_depth: 5
    learning_rate: 0.05
    train_test_split: 0.8
  anomaly:
    contamination: 0.05

# Signal Thresholds
signals:
  ai_trend_up_threshold: 0.70
  fng_buy_threshold: 15
  fng_sell_threshold: 85
  funding_sell_threshold: 0.02  # 2%

# Dashboard
dashboard:
  port: 8501
  theme: "dark"
